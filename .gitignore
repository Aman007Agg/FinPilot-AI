###############################################################################
# FinPilot AI - Enterprise .gitignore
# Supports:
# - Angular
# - .NET
# - Python / FastAPI
# - VS Code
# - Visual Studio
# - Docker
# - Kubernetes
###############################################################################

############################################
# Operating System
############################################

.DS_Store
Thumbs.db
desktop.ini

############################################
# Visual Studio
############################################

.vs/
*.user
*.suo
*.userosscache
*.sln.docstates

############################################
# Build Output (.NET)
############################################

bin/
obj/
Debug/
Release/
publish/

############################################
# Rider / ReSharper
############################################

_ReSharper*/
*.DotSettings.user

############################################
# VS Code
############################################

.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

############################################
# Node / Angular
############################################

node_modules/
dist/
.angular/
.angular-cache/
coverage/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

############################################
# Environment Files
############################################

.env
.env.*
!.env.example

############################################
# Python
############################################

__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.venv/
venv/
env/
ENV/

############################################
# FastAPI Logs
############################################

*.log

############################################
# SQL Server
############################################

*.mdf
*.ldf
*.ndf

############################################
# SQLite
############################################

*.db
*.sqlite
*.sqlite3

############################################
# Docker
############################################

docker-compose.override.yml

############################################
# Kubernetes
############################################

*.kubeconfig

############################################
# Terraform (Future)
############################################

.terraform/
*.tfstate
*.tfstate.*

############################################
# Azure
############################################

.azure/

############################################
# Secrets
############################################

secrets.json
*.pfx
*.pem
*.key

############################################
# Logs
############################################

logs/
*.log

############################################
# Temporary Files
############################################

tmp/
temp/
*.tmp

############################################
# Test Results
############################################

TestResults/

############################################
# NuGet
############################################

packages/
*.nupkg

############################################
# SonarQube
############################################

.scannerwork/

############################################
# JetBrains
############################################

.idea/

############################################
# Mac/Linux
############################################

.AppleDouble
.LSOverride

############################################
# Windows
############################################

ehthumbs.db

############################################
# Misc
############################################

*.bak
*.cache
*.orig